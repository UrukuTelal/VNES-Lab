# VNES-Lab API Keys
# Copy this file to .env and fill in your keys.
# Keys are loaded by rlaaer.data.scraper from environment variables.

# US Census Bureau API key (Tier 1 data source)
# https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=

# NASA API key (Tier 1 data source)
# https://api.nasa.gov/
NASA_API_KEY=

# NOAA Climate Data Online API key (Tier 1 data source)
# https://www.ncdc.noaa.gov/cdo-web/token
NOAA_API_KEY=

# Kaggle API key (Tier 2 data source)
# https://www.kaggle.com/settings
KAGGLE_API_KEY=
